# ============================================================
# AXEworks Foundation Engine - Environment Variables
# ============================================================

# --- LLM & AI Inference Model APIs (Engine Brain) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LOCAL_LLM_ENDPOINT="http://localhost:11434/api/generate"

# --- AXEngine: Internal Legacy System Connectors (Layer 1) ---
ERP_SYSTEM_ENDPOINT=""
ERP_API_KEY=""
MES_SYSTEM_ENDPOINT=""
MES_API_KEY=""
CRM_SYSTEM_ENDPOINT=""
CRM_API_KEY=""
INTERNAL_SAAS_API_KEY=""

# --- AXE_POE: External Product & Customer Data (Layer 1) ---
PRODUCT_DB_ENDPOINT=""
USER_ANALYTICS_API_KEY=""
CS_TICKET_SYSTEM_API=""
PAYMENT_GATEWAY_API=""

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=axeworks
POSTGRES_USER=axeworks
POSTGRES_PASSWORD=axeworks_dev_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Vector DB (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Service Ports ---
AXENGINE_PORT=8001
AXE_POE_PORT=8002
POLICY_ENGINE_PORT=8003
POQAT_PORT=8004
DATA_FOUNDATION_PORT=8005
COCKPIT_PORT=3000

# --- Security ---
JWT_SECRET="change-me-in-production"
API_KEY_SALT="change-me-in-production"

# --- Human-in-the-Loop ---
CONFIDENCE_THRESHOLD=0.80
